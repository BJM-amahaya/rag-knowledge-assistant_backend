# ──────────────────────────────────────────
# ベースイメージ: Python 3.11 の軽量版を使う
# ──────────────────────────────────────────
FROM python:3.11-slim

# ──────────────────────────────────────────
# 作業ディレクトリを /app に設定
# (コンテナ内でコードを置く場所)
# ──────────────────────────────────────────
WORKDIR /app

# ──────────────────────────────────────────
# 必要なシステムパッケージをインストール
# (一部のPythonパッケージのビルドに必要)
# ──────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential curl \
    && rm -rf /var/lib/apt/lists/*

# ──────────────────────────────────────────
# 依存パッケージ定義ファイルを先にコピー
# (コードが変わっても依存が変わらなければ
#  キャッシュが効いてビルドが速くなる)
# ──────────────────────────────────────────
COPY requirements.txt .

# ──────────────────────────────────────────
# Pythonパッケージをインストール
# ──────────────────────────────────────────
RUN pip install --no-cache-dir -r requirements.txt

# ──────────────────────────────────────────
# アプリのコードを全てコピー
# ──────────────────────────────────────────
COPY . .

# ──────────────────────────────────────────
# 永続化用ディレクトリを作成
# uploads/ : メタデータ(metadata.json)の保存先
# ──────────────────────────────────────────
RUN mkdir -p uploads

# ──────────────────────────────────────────
# コンテナが使うポート番号を宣言
# (実際の公開はdocker-compose側で設定)
# ──────────────────────────────────────────
EXPOSE 8000

# ──────────────────────────────────────────
# コンテナ起動時に実行するコマンド
# --host 0.0.0.0 : 外部からの接続を許可
# --port 8000    : ポート8000で起動
# ──────────────────────────────────────────
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
